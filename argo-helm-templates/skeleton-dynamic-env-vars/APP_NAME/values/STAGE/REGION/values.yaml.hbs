# Generated values for: {{ bkst_app_name }}
# Stage: {{ bkst_app_stage }}
# Region: {{ bkst_app_region }}

global:
  vars:
    ENV_NAME: "{{ bkst_app_stage }}"
  env:
    AWS_REGION: "{{ bkst_app_region }}"

{{ bkst_app_name }}:
  enabled: true
  appId: {{ bkst_app_name }}

  {%- if envVariables and envVariables | length > 0 %}
  # ConfigMap with regular environment variables
  cm:
    enabled: true
    env:
    {%- for var in envVariables %}
      {{ var.varName }}: "{{ var.varValue }}"
    {%- endfor %}
    dynamic:
      DATASOURCE_DB_URL: "jdbc:postgresql://{{ .Values.global.vars.BASE_DB_URL }}:5432/postgres?{{ .Values.global.vars.BASE_DB_OPTS }}"
      REGION_NAME: "{{ .Values.global.env.AWS_REGION }}"
      AWS_REGION: "{{ .Values.global.env.AWS_REGION }}"
      AWS_DEFAULT_REGION: "{{ .Values.global.env.AWS_REGION }}"
  {%- else %}
  cm:
    enabled: true
    env: {}
    dynamic:
      DATASOURCE_DB_URL: "jdbc:postgresql://{{ .Values.global.vars.BASE_DB_URL }}:5432/postgres?{{ .Values.global.vars.BASE_DB_OPTS }}"
      REGION_NAME: "{{ .Values.global.env.AWS_REGION }}"
      AWS_REGION: "{{ .Values.global.env.AWS_REGION }}"
      AWS_DEFAULT_REGION: "{{ .Values.global.env.AWS_REGION }}"
  {%- endif %}

  {%- if secretVariables and secretVariables | length > 0 %}
  # External Secrets Configuration for sensitive data
  externalsecretEnv:
    enabled: true
    env:
    {%- for secret in secretVariables %}
      - name: {{ secret.secretVarName }}
        key: "{{ secret.secretStoreKey }}"
        property: "{{ secret.secretProperty }}"
    {%- endfor %}
  {%- else %}
  externalsecretEnv:
    enabled: false
    env: []
  {%- endif %}

  ingress:
    enabled: true
    annotations:
      alb.ingress.kubernetes.io/actions.response-503: |
        {"type":"fixed-response","fixedResponseConfig":{"contentType":"text/plain","statusCode":"503","messageBody":"503 Service Unavailable"}}
      alb.ingress.kubernetes.io/actions.ssl-redirect: '{"Type": "redirect", "RedirectConfig":
        { "Protocol": "HTTPS", "Port": "443", "StatusCode": "HTTP_301"}}'
      alb.ingress.kubernetes.io/group.name: public
      alb.ingress.kubernetes.io/healthcheck-path: /
      alb.ingress.kubernetes.io/listen-ports: '[{"HTTP": 80}, {"HTTPS": 443}]'
      alb.ingress.kubernetes.io/scheme: internet-facing
      alb.ingress.kubernetes.io/success-codes: 200-404
      alb.ingress.kubernetes.io/target-type: ip
      kubernetes.io/ingress.class: alb
    dynamic:
      enabled: true
      nsPrefix: false
      tls: true
      cfgs:
      - name: {{ bkst_app_name }}
        paths:
          - /
        port: 80

  service:
    enabled: true
    external: false
    ports:
    - name: application
      port: 80
      protocol: TCP
      targetPort: application

  deployment:
    enabled: true
    replicaCount: 1
    image:
      ecr: "docker.io"
      repository: "{{ bkst_app_imagename }}"
      tag: "{{ bkst_app_image_tag }}"
      pullPolicy: "Always"

    securityContext:
      enabled: false
      runAsUser: 0
      fsGroup: 101

    ports:
    - name: application
      containerPort: 80
      protocol: TCP

    resources:
      enabled: true
      requests:
        memory: {{ bkst_app_mem }}
        cpu: 50m
      limits:
        memory: {{ bkst_app_mem }}
        cpu: {{ bkst_app_cpu_limit }}

    probes:
      enabled: true
      content:
        startupProbe:
          httpGet:
            path: {{ bkst_app_health_probe }}
            port: 80
          initialDelaySeconds: 10
          timeoutSeconds: 5
          periodSeconds: 10
          failureThreshold: 20

        livenessProbe:
          httpGet:
            path: {{ bkst_app_health_probe }}
            port: 80
          initialDelaySeconds: 10
          timeoutSeconds: 5
          periodSeconds: 60
          failureThreshold: 2

        readinessProbe:
          httpGet:
            path: {{ bkst_app_health_probe }}
            port: 80
          initialDelaySeconds: 10
          timeoutSeconds: 5
          periodSeconds: 60
          failureThreshold: 2

  jobs: []
