global:
  vars:
    ENV_NAME: "${{ values.bkst_app_stage }}"
  env:
    AREGION: "${{ values.bkst_app_region }}"

${{ values.bkst_app_name }}:
  enabled: true
  appId: ${{ values.bkst_app_name }}
  cm:
    enabled: true
    env:
      SAMPLE_VAR: "sampleval"
    dynamic:
      DATASOURCE_DB_URL: "jdbc:postgresql://{{ .Values.global.vars.BASE_DB_URL }}:5432/postgres?{{ .Values.global.vars.BASE_DB_OPTS }}"
      REGION_NAME: "{{ .Values.global.env.REGION }}"
      REGION: "{{ .Values.global.env.REGION }}"

  ingress:
    enabled: true
    annotations:
      kubernetes.io/ingress.class: traefik
    dynamic:
      enabled: true
      nsPrefix: false
      tls: true
      cfgs:
      - name: ${{ values.bkst_app_name }}
        paths:
          - /
        port: 80

  deployment:
    enabled: true
    replicaCount: 1
    image:
      ecr: "${{ values.bkst_app_imagereg }}"
      repository: "${{ values.bkst_app_imagename}}"
      tag: "${{ values.bkst_app_image_tag }}"
      pullPolicy: "Always"

    securityContext:
      enabled: false
      runAsUser: 0
      fsGroup: 101

    ports:
    - name: application
      containerPort: 80
      protocol: TCP

    resources:
      enabled: true
      requests:
        memory: ${{ values.bkst_app_mem }}
        cpu: 50m
      limits:
        memory: ${{ values.bkst_app_mem }}
        cpu: ${{ values.bkst_app_cpu_limit }}

    probes:
      enabled: true
      content:
        startupProbe:
          httpGet:
            path: ${{ values.bkst_app_health_probe }}
            port: 80
          initialDelaySeconds: 10
          timeoutSeconds: 5
          periodSeconds: 10
          failureThreshold: 20

        livenessProbe:
          httpGet:
            path: ${{ values.bkst_app_health_probe }}
            port: 80
          initialDelaySeconds: 10
          timeoutSeconds: 5
          periodSeconds: 60
          failureThreshold: 2

        readinessProbe:
          httpGet:
            path: ${{ values.bkst_app_health_probe }}
            port: 80
          initialDelaySeconds: 10
          timeoutSeconds: 5
          periodSeconds: 60
          failureThreshold: 2

  jobs: []
