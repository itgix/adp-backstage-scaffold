# Generated values for: ${{ values.bkst_app_name }}
# Stage: ${{ values.bkst_app_stage }}
# Region: ${{ values.bkst_app_region }}

global:
  vars:
    ENV_NAME: "${{ values.bkst_app_stage }}"
  env:
    REGION: "${{ values.bkst_app_region }}"

${{ values.bkst_app_name }}:
  enabled: true
  appId: ${{ values.bkst_app_name }}

  {%- if values.envVariables and values.envVariables | length > 0 %}
  # ConfigMap with regular environment variables
  cm:
    enabled: true
    env:
    {%- for var in values.envVariables %}
      ${{ var.varName }}: "${{ var.varValue }}"
    {%- endfor %}
    dynamic:
      SAMPLE_DATASOURCE_DB_URL: "jdbc:postgresql://{{ .Values.global.vars.BASE_DB_URL }}:5432/postgres?{{ .Values.global.vars.BASE_DB_OPTS }}"

  {%- else %}
  cm:
    enabled: true
    env: {}
    dynamic:
      DATASOURCE_DB_URL: "jdbc:postgresql://{{ .Values.global.vars.BASE_DB_URL }}:5432/postgres?{{ .Values.global.vars.BASE_DB_OPTS }}"
      REGION_NAME: "{{ .Values.global.env.REGION }}"
  {%- endif %}

  {%- if values.secretVariables and values.secretVariables | length > 0 %}
  # External Secrets Configuration for sensitive data
  externalsecretEnv:
    enabled: true
    env:
    {%- for secret in values.secretVariables %}
      - name: ${{ secret.secretVarName }}
        key: "${{ secret.secretStoreKey }}"
        property: "${{ secret.secretProperty }}"
    {%- endfor %}
  {%- else %}
  externalsecretEnv:
    enabled: false
    env: []
  {%- endif %}

  {%- if values.enableIngress %}
  ingress:
    enabled: true
    annotations:
      cert-manager.io/cluster-issuer: "letsencrypt-prod"
      kubernetes.io/ingress.class: traefik
    dynamic:
      enabled: true
      nsPrefix: false
      tls: true
      cfgs:
      - name: ${{ values.bkst_app_name }}
        hosts:
        {%- if values.ingressUrl %}
          - ${{ values.ingressUrl }}
        {%- else %}
          - ${{ values.bkst_app_name }}.example.com
        {%- endif %}
        paths:
          - /
        port: 80
        tls:
          enabled: true
        {%- if values.ingressUrl %}
          secretName: ${{ values.bkst_app_name }}-tls
          hosts:
            - ${{ values.ingressUrl }}
        {%- endif %}
  {%- else %}
  ingress:
    enabled: false
  {%- endif %}

  service:
    enabled: true
    external: false
    ports:
    - name: application
      port: 80
      protocol: TCP
      targetPort: application

  deployment:
    enabled: true
    replicaCount: 1
    image:
      pullSecret:
        enabled: true
        externalSecret: true
        secretName: registry-pull-secret
        registry: registry.phoenix.net-digital.com
        vaultKey: "common/image_registry_pull_secret"
      ecr: ""
      repository: "${{ values.bkst_app_imagename }}"
      tag: "${{ values.bkst_app_image_tag }}"
      pullPolicy: "Always"

    securityContext:
      enabled: false
      runAsUser: 0
      fsGroup: 101

    ports:
    - name: application
      containerPort: ${{ values.bkst_app_listen_port }}
      protocol: TCP

    resources:
      enabled: true
      requests:
        memory: ${{ values.bkst_app_mem }}
        cpu: 50m
      limits:
        memory: ${{ values.bkst_app_mem }}
        cpu: ${{ values.bkst_app_cpu_limit }}

    probes:
      enabled: true
      content:
        startupProbe:
          httpGet:
            path: ${{ values.bkst_app_health_probe }}
            port: ${{ values.bkst_app_listen_port }}
          initialDelaySeconds: 10
          timeoutSeconds: 5
          periodSeconds: 10
          failureThreshold: 20

        livenessProbe:
          httpGet:
            path: ${{ values.bkst_app_health_probe }}
            port: ${{ values.bkst_app_listen_port }}
          initialDelaySeconds: 10
          timeoutSeconds: 5
          periodSeconds: 60
          failureThreshold: 2

        readinessProbe:
          httpGet:
            path: ${{ values.bkst_app_health_probe }}
            port: ${{ values.bkst_app_listen_port }}
          initialDelaySeconds: 10
          timeoutSeconds: 5
          periodSeconds: 60
          failureThreshold: 2

  jobs: []
